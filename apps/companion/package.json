{
  "name": "@bubble-town/companion",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/standalone.ts",
    "dev:lan": "COMPANION_HOST=0.0.0.0 tsx watch src/standalone.ts",
    "check": "tsc -p tsconfig.json --noEmit",
    "build": "tsc -p tsconfig.json && esbuild src/standalone.ts --bundle --platform=node --format=cjs --sourcemap --outfile=dist/server.cjs",
    "test": "tsx --test $(find src -name '*.test.ts')",
    "test:2.2.3": "tsx --test src/features/memory/memory-intelligence.test.ts src/features/memory/memory-governance.test.ts"
  },
  "dependencies": {
    "@bubble-town/shared": "file:../../packages/shared",
    "@fastify/cors": "^10.0.2",
    "fastify": "^5.3.3",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "esbuild": "^0.28.0",
    "tsx": "^4.19.4",
    "typescript": "~5.8.3"
  }
}
